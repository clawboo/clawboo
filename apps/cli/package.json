{
  "name": "clawboo",
  "version": "0.2.0",
  "description": "A TypeScript orchestrator for heterogeneous AI agent runtimes: native agents built in, with Claude Code, Codex, Hermes, and OpenClaw as peer teammates in one chat.",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/clawboo/clawboo.git",
    "directory": "apps/cli"
  },
  "homepage": "https://github.com/clawboo/clawboo",
  "bugs": "https://github.com/clawboo/clawboo/issues",
  "keywords": [
    "ai-agents",
    "multi-agent",
    "ai-orchestrator",
    "claude-code",
    "codex",
    "openclaw",
    "mcp",
    "cli",
    "mission-control"
  ],
  "bin": {
    "clawboo": "dist/index.js",
    "clawboo-mcp-tasks": "dist/bin/tasks.js",
    "clawboo-mcp-memory": "dist/bin/memory.js",
    "clawboo-mcp-tools": "dist/bin/tools.js",
    "clawboo-mcp-teamchat": "dist/bin/teamchat.js"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "lint": "eslint src/",
    "typecheck": "tsc --noEmit"
  },
  "engines": {
    "node": ">=22.0.0"
  },
  "dependencies": {
    "@clack/prompts": "^0.9.0",
    "better-sqlite3": "11.10.0",
    "chalk": "^5.4.0",
    "commander": "^12.1.0",
    "ora": "^8.1.0",
    "pino": "^9.6.0",
    "pino-pretty": "^13.0.0",
    "ws": "8.19.0"
  },
  "devDependencies": {
    "@clawboo/config": "workspace:*",
    "@clawboo/tsconfig": "workspace:*",
    "@types/node": "^22.0.0",
    "tsup": "^8.4.0",
    "typescript": "^5.7.0"
  }
}
