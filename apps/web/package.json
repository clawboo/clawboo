{
  "name": "@clawboo/web",
  "version": "0.0.0",
  "private": true,
  "scripts": {
    "dev": "concurrently -n api,ui -c blue,green \"pnpm dev:api\" \"pnpm dev:ui\"",
    "dev:api": "tsx watch server/index.ts --dev",
    "dev:ui": "vite",
    "build": "vite build && tsup --config tsup.server.config.ts",
    "build:ui": "vite build",
    "build:server": "tsup --config tsup.server.config.ts",
    "start": "CLAWBOO_UI_DIR=./dist/ui tsx server/index.ts",
    "lint": "eslint src/",
    "typecheck": "tsc --noEmit",
    "test": "vitest run"
  },
  "dependencies": {
    "@clawboo/config": "workspace:*",
    "@clawboo/db": "workspace:*",
    "@clawboo/events": "workspace:*",
    "@clawboo/gateway-client": "workspace:*",
    "@clawboo/gateway-proxy": "workspace:*",
    "@clawboo/logger": "workspace:*",
    "@clawboo/protocol": "workspace:*",
    "@clawboo/ui": "workspace:*",
    "@codemirror/autocomplete": "^6.20.1",
    "@codemirror/commands": "^6.10.2",
    "@codemirror/lang-markdown": "^6.5.0",
    "@codemirror/language": "^6.12.2",
    "@codemirror/search": "^6.6.0",
    "@codemirror/state": "^6.5.4",
    "@codemirror/theme-one-dark": "^6.1.3",
    "@codemirror/view": "^6.39.16",
    "@lezer/highlight": "^1.2.3",
    "@radix-ui/react-slider": "^1.3.6",
    "@tanstack/react-query": "^5.0.0",
    "@xyflow/react": "^12.10.1",
    "codemirror": "^6.0.2",
    "cors": "^2.8.6",
    "drizzle-orm": "^0.38.0",
    "elkjs": "^0.9.3",
    "express": "^5.2.1",
    "framer-motion": "^11.0.0",
    "lucide-react": "^0.468.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-markdown": "^9.0.0",
    "recharts": "^2.13.0",
    "remark-gfm": "^4.0.0",
    "zustand": "^5.0.0"
  },
  "devDependencies": {
    "@clawboo/tsconfig": "workspace:*",
    "@tailwindcss/postcss": "^4.0.0",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/node": "^22.0.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react": "^4.3.0",
    "concurrently": "^9.2.1",
    "tailwindcss": "^4.0.0",
    "tsx": "^4.19.0",
    "tsup": "^8.4.0",
    "typescript": "^5.7.0",
    "vite": "^6.0.0",
    "vite-tsconfig-paths": "^5.1.0"
  }
}
