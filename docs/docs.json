    "light": "/logo/light.svg",
    "dark": "/logo/dark.svg",
    "href": "/"
  },
  "icons": {
    "library": "lucide"
  },
  "fonts": {
    "heading": {
      "family": "Cabinet Grotesk",
      "weight": 800,
      "source": "/fonts/CabinetGrotesk-Extrabold.woff2",
      "format": "woff2"
    },
    "body": {
      "family": "DM Sans"
    }
  },
  "appearance": {
    "default": "system",
    "strict": false
  },
  "background": {
    "decoration": "gradient",
    "color": {
      "light": "#f8fafc",
      "dark": "#0a0e1a"
    }
  },
  "styling": {
    "eyebrows": "breadcrumbs",
    "codeblocks": {
      "theme": {
        "light": "github-dark",
        "dark": "github-dark"
      }
    }
  },
