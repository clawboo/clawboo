{
  "$schema": "https://mintlify.com/docs.json",
  "theme": "maple",
  "name": "Clawboo",
  "colors": {
    "primary": "#dc2a48",
    "light": "#e94560",
    "dark": "#e94560"
  },
  "favicon": "/favicon.svg",
