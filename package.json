{
  "name": "clawboo-root",
  "private": true,
  "scripts": {
    "build": "turbo build",
    "dev": "turbo dev --concurrency=20",
    "lint": "turbo lint",
    "typecheck": "turbo typecheck",
    "test": "turbo test",
    "e2e": "playwright test",
    "assemble": "pnpm build && bash scripts/assemble-cli.sh",
    "format": "prettier --write .",
    "prepare": "husky",
    "ingest:marketplace": "tsx scripts/ingest-marketplace-content.ts",
    "verify:ingest": "tsx scripts/verify-ingest.ts",
    "test:clean-install": "node scripts/test-clean-install.mjs",
    "prepublish:check": "pnpm assemble && pnpm test:clean-install"
  },
  "devDependencies": {
    "@changesets/cli": "^2.27.0",
    "@eslint/js": "^9.0.0",
    "@playwright/test": "^1.50.0",
    "@testing-library/jest-dom": "^6.6.0",
    "@testing-library/react": "^16.0.0",
    "@testing-library/user-event": "^14.5.0",
    "@types/jest-axe": "^3.5.9",
    "@types/node": "^22.0.0",
    "@types/ws": "^8.5.0",
    "eslint": "^9.0.0",
    "eslint-config-prettier": "^9.0.0",
    "husky": "^9.0.0",
    "jest-axe": "^10.0.0",
    "jsdom": "^25.0.0",
    "lint-staged": "^15.0.0",
    "msw": "^2.7.0",
    "prettier": "^3.4.0",
    "tsup": "^8.4.0",
    "tsx": "^4.19.0",
    "turbo": "^2.3.0",
    "typescript": "^5.7.0",
    "typescript-eslint": "^8.0.0",
    "vitest": "^3.0.0",
    "ws": "^8.18.0"
  },
  "lint-staged": {
    "*.{ts,tsx,js,mjs,cjs}": [
      "eslint --fix --max-warnings 0",
      "prettier --write"
    ],
    "*.{json,md,yaml,yml,css}": [
      "prettier --write"
    ]
  },
  "engines": {
    "node": ">=22.0.0",
    "pnpm": ">=9.0.0"
  },
  "packageManager": "pnpm@9.15.0"
}
