{
  "name": "@clawboo/adapter-openclaw",
  "version": "0.1.0",
  "private": true,
  "description": "OpenClaw RuntimeAdapter — wraps the Gateway client into the normalized executor lifecycle stream",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/clawboo/clawboo.git",
    "directory": "packages/adapters/openclaw"
  },
  "homepage": "https://github.com/clawboo/clawboo/tree/main/packages/adapters/openclaw",
  "bugs": "https://github.com/clawboo/clawboo/issues",
  "keywords": [
    "clawboo",
    "executor",
    "adapter",
    "openclaw",
    "gateway"
  ],
  "files": [
    "dist"
  ],
  "main": "dist/index.js",
  "module": "dist/index.mjs",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsup",
    "lint": "eslint src/",
    "typecheck": "tsc --noEmit",
    "test": "vitest run"
  },
  "dependencies": {
    "@clawboo/events": "workspace:*",
    "@clawboo/executor": "workspace:*",
    "@clawboo/gateway-client": "workspace:*",
    "@clawboo/logger": "workspace:*",
    "@clawboo/protocol": "workspace:*"
  },
  "devDependencies": {
    "@clawboo/tsconfig": "workspace:*",
    "tsup": "^8.4.0",
    "typescript": "^5.7.0",
    "vitest": "^3.0.0"
  }
}
