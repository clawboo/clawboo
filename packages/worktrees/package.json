    "zod": "^3.25.0"
  },
  "devDependencies": {
    "@clawboo/tsconfig": "workspace:*",
    "@types/node": "^22.0.0",
    "tsup": "^8.4.0",
    "typescript": "^5.7.0",
    "vitest": "^3.0.0"
  }
}
