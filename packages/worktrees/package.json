    "directory": "packages/worktrees"
  },
  "homepage": "https://github.com/clawboo/clawboo/tree/main/packages/worktrees",
  "bugs": "https://github.com/clawboo/clawboo/issues",
  "keywords": [
    "clawboo",
    "git-worktree",
    "system-of-record",
    "handoff",
    "isolation"
  ],
  "files": [
    "dist"
  ],
  "main": "dist/index.js",
